 click taskbar icon, 3) Windows search.","inputSchema":{"type":"object","properties":{"appName":{"description":"App name to open (e.g. \u0027Telegram\u0027, \u0027Spotify\u0027, \u0027Chrome\u0027)","type":"string"}},"required":["appName"]}},{"name":"keyboard_key_up","description":"Release a held key.","inputSchema":{"type":"object","properties":{"key":{"description":"Key name to release","type":"string"}},"required":["key"]}},{"name":"ocr_window","description":"Run OCR on an entire window. Auto-enhances dark themes. Returns all visible text with click coordinates.","inputSchema":{"type":"object","properties":{"windowTitle":{"description":"Part of window title (case-insensitive)","type":"string"},"language":{"description":"Language code (default: en)","type":"string","default":"en"}},"required":["windowTitle"]}},{"name":"restore_window","description":"Restore a minimized/maximized window to normal size.","inputSchema":{"type":"object","properties":{"windowTitle":{"description":"Part of the window title (case-insensitive)","type":"string"}},"required":["windowTitle"]}},{"name":"paste_text","description":"Set clipboard to the given text and paste via Ctrl\u002BV. Reliable for large text like XML, code, or multi-line content that keyboard_type can\u0027t handle.","inputSchema":{"type":"object","properties":{"text":{"description":"Text to paste","type":"string"}},"required":["text"]}},{"name":"keyboard_key_down","description":"Press and hold a key without releasing. Use keyboard_key_up to release.","inputSchema":{"type":"object","properties":{"key":{"description":"Key name to hold","type":"string"}},"required":["key"]}},{"name":"set_clipboard","description":"Set the system clipboard text without pasting. Useful for preparing large text (XML, code, JSON) to paste manually or with Ctrl\u002BV.","inputSchema":{"type":"object","properties":{"text":{"description":"Text to put on clipboard","type":"string"}},"required":["text"]}},{"name":"scan_desktop","description":"Full desktop scan: screens, windows (with visibility %), UI elements, desktop regions, taskbar. Returns compact plain text.","inputSchema":{"type":"object","properties":{}}},{"name":"focus_and_hotkey","description":"Click at coordinates to ensure focus (e.g. inside an iframe), wait, then send a keyboard shortcut. Solves iframe/web app focus issues where separate click \u002B hotkey calls fail.","inputSchema":{"type":"object","properties":{"x":{"description":"X coordinate to click for focus","type":"integer"},"y":{"description":"Y coordinate to click for focus","type":"integer"},"key1":{"description":"First key (e.g. ctrl, alt, shift)","type":"string"},"key2":{"description":"Second key","type":"string","default":""},"key3":{"description":"Optional third key","type":"string","default":""},"key4":{"description":"Optional fourth key","type":"string","default":""},"delayMs":{"description":"Delay in ms between click and hotkey (default 200, range 50-2000)","type":"integer","default":200}},"required":["x","y","key1"]}},{"name":"type_in_element","description":"Find input element and type text. Tries ValuePattern, then clipboard paste, then click\u002Btype.","inputSchema":{"type":"object","properties":{"elementText":{"description":"Text/label of input to find","type":"string"},"value":{"description":"Text to type","type":"string"},"windowLabel":{"description":"Limit to window","type":"string","default":""}},"required":["elementText","value"]}},{"name":"mouse_move","description":"Move the mouse cursor to absolute screen coordinates. Works across all monitors.","inputSchema":{"type":"object","properties":{"x":{"description":"X coordinate (can be negative for left-side monitors)","type":"integer"},"y":{"description":"Y coordinate","type":"integer"}},"required":["x","y"]}},{"name":"maximize_window","description":"Maximize a window by title.","inputSchema":{"type":"object","properties":{"windowTitle":{"description":"Part of the window title (case-insensitive)","type":"string"}},"required":["windowTitle"]}},{"name":"run_sequence","description":"Execute multiple UI actions in a single call. Massively faster than individual tool calls. Each line is one action. Actions:\n  click \u0022text\u0022           \u2014 click element by text (UIAutomation \u002B OCR fallback)\n  click x,y              \u2014 click at screen coordinates\n  doubleclick x,y        \u2014 double-click at coordinates\n  type \u0022text\u0022            \u2014 type text via keyboard\n  paste \u0022text\u0022           \u2014 paste via clipboard (for large/XML text)\n  hotkey ctrl\u002Ba          \u2014 press key combination\n  wait 500               \u2014 wait N milliseconds\n  focus \u0022window title\u0022   \u2014 focus a window\n  tab \u0022tab text\u0022         \u2014 select a browser tab\n  ocr_click \u0022text\u0022       \u2014 find text via OCR and click it (skips UIAutomation)\n  screenshot \u0022path\u0022      \u2014 take screenshot of focused window\nExample: focus \u0022Chrome\u0022\\nwait 300\\nclick \u0022Extras\u0022\\nwait 500\\nclick \u0022Edit Diagram\u0022","inputSchema":{"type":"object","properties":{"actions":{"description":"Actions to execute, one per line","type":"string"},"windowTitle":{"description":"Window to focus before starting (optional)","type":"string","default":""}},"required":["actions"]}},{"name":"ocr_find_text","description":"Use OCR to find specific text on screen and return its click coordinates. Auto-enhances dark themes.","inputSchema":{"type":"object","properties":{"searchText":{"description":"Text to search for (case-insensitive)","type":"string"},"x":{"description":"Left edge X of search region","type":"integer"},"y":{"description":"Top edge Y of search region","type":"integer"},"width":{"description":"Width of search region","type":"integer"},"height":{"description":"Height of search region","type":"integer"},"language":{"description":"Language code (default: en)","type":"string","default":"en"}},"required":["searchText","x","y","width